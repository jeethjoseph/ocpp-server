# ===========================================
# Docker Environment Configuration - PRODUCTION
# Copy this file to .env.prod and fill in values
# KEEP THIS FILE SECURE - NEVER COMMIT TO GIT
# ===========================================

# Environment Mode
ENVIRONMENT=production

# ===========================================
# Domain Configuration (REQUIRED)
# ===========================================
DOMAIN_NAME=yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# ===========================================
# Database Configuration (REQUIRED)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=ocpp_prod
DB_PASSWORD=your_very_secure_production_password
DB_NAME=ocpp_prod_db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Backend Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=warning

# ===========================================
# Frontend Configuration (REQUIRED)
# ===========================================
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ===========================================
# Monitoring Configuration (REQUIRED for production)
# ===========================================

# New Relic APM
NEW_RELIC_MONITOR_MODE=true
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
NEW_RELIC_APP_NAME=OCPP-Server-Production
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# Sentry Error Tracking
SENTRY_ENABLED=true
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production

# ===========================================
# Frontend New Relic Browser
# ===========================================
NEXT_PUBLIC_NEW_RELIC_BROWSER_LICENSE_KEY=your-browser-license-key
NEXT_PUBLIC_NEW_RELIC_APPLICATION_ID=your-app-id
NEXT_PUBLIC_NEW_RELIC_ACCOUNT_ID=your-account-id
NEXT_PUBLIC_NEW_RELIC_TRUST_KEY=your-trust-key
NEXT_PUBLIC_NEW_RELIC_AGENT_ID=your-agent-id

# ===========================================
# Clerk Authentication (REQUIRED)
# ===========================================
# Backend
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_WEBHOOK_SECRET=your-clerk-webhook-secret
# JWT verification — production uses Clerk custom domain
CLERK_JWKS_URL=https://clerk.voltlync.com/.well-known/jwks.json
CLERK_ISSUER=https://clerk.voltlync.com

# CORS origins (comma-separated)
CORS_ORIGINS=https://app.voltlync.com

# Frontend
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# ===========================================
# Razorpay Payment Gateway (REQUIRED)
# ===========================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ===========================================
# QR Payment Tuning (Optional - defaults shown)
# ===========================================
RAZORPAY_PLATFORM_FEE_PERCENT=2.0
QR_PAYMENT_PENDING_TIMEOUT=300

# ===========================================
# Razorpay Route — franchisee payouts (Optional)
# ===========================================
# Master switch: when false, settlement transfers are not initiated.
RAZORPAY_ROUTE_ENABLED=false
# Wallet-funded sessions require Razorpay to enable POST /v1/transfers
# ("Direct Transfer") on the merchant account. Until activated, leave this
# false — wallet entries park in ON_HOLD (failure_reason=
# wallet_settlement_not_activated) and the retry loop skips them. QR/UPI
# settlements use the payment-based endpoint and are unaffected.
WALLET_SETTLEMENT_ENABLED=false
# Minimum INR amount per transfer; below this the entry is skipped.
MINIMUM_TRANSFER_AMOUNT=1.00
# Max retry attempts per CommissionLedgerEntry before manual triage.
MAX_TRANSFER_RETRIES=3
# Background retry-loop cadence (seconds). 600 = 10 minutes.
FRANCHISEE_PAYOUT_RETRY_INTERVAL_SECONDS=600

# ===========================================
# OCPP & Server Tuning (Optional - defaults shown)
# ===========================================
SUSPEND_TIMEOUT_SECONDS=300
OCPP_TIMEOUT=120
RETENTION_DAYS=90
CLEANUP_INTERVAL_HOURS=24
DEBUG=false

# ===========================================
# VoltLync supplier identity (REQUIRED for GST invoices)
# ===========================================
VOLTLYNC_BUSINESS_NAME=VOLTLYNC PRIVATE LIMITED
VOLTLYNC_GSTIN=                       # 15-char GSTIN; invoices not issued when empty
VOLTLYNC_ADDRESS=
VOLTLYNC_STATE=Kerala
VOLTLYNC_STATE_CODE=32

# ===========================================
# Invoice PDF persistence (S3, lazy upload)
# ===========================================
AWS_REGION=ap-south-1
AWS_S3_INVOICE_BUCKET=voltlync-invoices-prod
