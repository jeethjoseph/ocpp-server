# ===========================================
# Docker Environment Configuration - STAGING
# Copy this file to .env.staging and fill in values
# ===========================================

# Environment Mode
ENVIRONMENT=staging

# ===========================================
# Domain Configuration (REQUIRED)
# ===========================================
DOMAIN_NAME=staging.yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# ===========================================
# Database Configuration (REQUIRED)
# ===========================================
# DB_HOST:
#   - Pre-RDS-migration: 'postgres' (Docker network name)
#   - Post-RDS-migration: 'ocpp-staging-db.cXXXXXXX.ap-south-1.rds.amazonaws.com'
DB_HOST=postgres
DB_PORT=5432
DB_USER=ocpp_staging
DB_PASSWORD=your_secure_staging_password
DB_NAME=ocpp_staging_db

# TLS mode for Postgres connection.
# - Empty/unset: legacy behavior (disable for local/Docker hosts, require otherwise)
# - 'verify-full': required for RDS. Uses the CA bundle baked into the backend
#   image at /etc/ssl/rds-ca-bundle.pem during build.
# - Other valid values: disable, allow, prefer, require, verify-ca
DB_SSL_MODE=

# Only used during RDS admin/setup tasks (creating app users, ad-hoc admin SQL).
# Not read by the running backend; the backend uses DB_PASSWORD at runtime.
# Generated at provisioning time and stored only here on the EC2 host.
RDS_MASTER_PASSWORD=
# App-side RDS password generated at provisioning time. At cutover this value
# becomes DB_PASSWORD; the variable can be removed after the validation window.
RDS_APP_PASSWORD=

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Backend Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=info

# ===========================================
# Frontend Configuration (REQUIRED)
# ===========================================
# API URL must be HTTPS for staging
NEXT_PUBLIC_API_URL=https://staging.yourdomain.com

# ===========================================
# Monitoring Configuration
# ===========================================

# New Relic APM
NEW_RELIC_MONITOR_MODE=true
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
NEW_RELIC_APP_NAME=OCPP-Server-Staging
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
NEW_RELIC_APPLICATION_LOGGING_FORWARDING_ENABLED=true

# Sentry Error Tracking
SENTRY_ENABLED=true
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=staging
# Optional perf/profiling sample rates (defaults: 0.1 = 10%). Set to 0 to disable
# traces/profiles entirely and keep within the free-tier Spans budget.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Release tag attached to every Sentry event. Normally left unset here —
# `make staging-rebuild` injects GIT_COMMIT=$(git rev-parse --short HEAD) at deploy.
# Set SENTRY_RELEASE explicitly only to override (e.g. a tagged release name).
# GIT_COMMIT=
# SENTRY_RELEASE=

# ===========================================
# Frontend New Relic Browser
# ===========================================
# All 5 vars must be set or the browser agent is skipped at runtime.
# Build-time only: changes require `make staging-rebuild-service SERVICE=frontend`.
NEXT_PUBLIC_NEW_RELIC_BROWSER_LICENSE_KEY=your-browser-license-key
NEXT_PUBLIC_NEW_RELIC_APPLICATION_ID=your-app-id
NEXT_PUBLIC_NEW_RELIC_ACCOUNT_ID=your-account-id
NEXT_PUBLIC_NEW_RELIC_TRUST_KEY=your-trust-key
NEXT_PUBLIC_NEW_RELIC_AGENT_ID=your-agent-id
# Wallet charging gate (ADR 0011). Default true; set "false" to hide the wallet
# UI. Build-time — re-enabling requires a frontend rebuild. Pair with the
# backend WALLET_CHARGING_ENABLED above.
NEXT_PUBLIC_WALLET_CHARGING_ENABLED=true

# ===========================================
# Frontend Sentry (Error Tracking)
# ===========================================
# DSN from Sentry: Project Settings → Client Keys (DSN). Build-time only.
NEXT_PUBLIC_SENTRY_DSN=your-frontend-sentry-dsn
# Source map upload: required for readable stack traces in Sentry UI.
# SENTRY_AUTH_TOKEN must be an "Internal Integration" token with `project:releases` + `project:read` scopes.
# Without it, errors still report but stack traces stay minified.
SENTRY_ORG=idofthings
SENTRY_PROJECT=ocpp-frontend
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===========================================
# Clerk Authentication (REQUIRED)
# ===========================================
# Backend
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_WEBHOOK_SECRET=your-clerk-webhook-secret
# JWT verification — set to your Clerk dev tenant or staging custom domain
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# CORS origins (comma-separated)
CORS_ORIGINS=https://staging.voltlync.com

# Frontend
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# Nginx CSP allow-list for Clerk origins. Space-separated. Staging uses
# the Clerk dev/multi-tenant wildcard. Read by nginx entrypoint envsubst.
CSP_CLERK_HOSTS=https://*.clerk.accounts.dev

# ===========================================
# Razorpay Payment Gateway (Optional)
# ===========================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Authoritative synthetic platform-fee rate (%) — drives budget cap, refunds,
# invoice gateway lines. ADR 0001. Startup refuses to launch if ≤0 or >10;
# 5–10 logs a warning but proceeds. Real-world Razorpay rates: 0–3%.
RAZORPAY_PLATFORM_FEE_PERCENT=2.0

# Razorpay instant refund kill-switch (ADR 0002). When true, _full_refund
# requests speed=optimum so customers see refunds in minutes; VoltLync
# absorbs the per-refund instant fee. Set false to revert to normal speed
# (5–7 working days, free) in an incident — no code change needed.
RAZORPAY_INSTANT_REFUND_ENABLED=true

# ===========================================
# Razorpay Route — franchisee payouts (Optional)
# ===========================================
# Master switch: when false, settlement transfers are not initiated even
# if a franchisee is fully onboarded. Useful for staging dry-runs.
RAZORPAY_ROUTE_ENABLED=false
# Wallet charging gate (ADR 0011). Default true. Set false to block NEW wallet
# sessions and top-ups (remote-start + recharge endpoints return 403) until the
# pooled multi-franchisee settlement ledger + Razorpay Direct Transfer exist.
# Existing balances, in-flight sessions, wallet billing, and all QR flows are
# unaffected. Backend is the source of truth; restart to apply (no rebuild).
WALLET_CHARGING_ENABLED=true
# Wallet-funded sessions require Razorpay's "Direct Transfer" feature
# (POST /v1/transfers) to be activated on the merchant account. While off,
# wallet entries park ON_HOLD (failure_reason=wallet_settlement_not_activated)
# and the retry loop skips them. QR/UPI settlements are unaffected.
WALLET_SETTLEMENT_ENABLED=false
# Minimum INR amount per transfer; below this the entry is skipped.
MINIMUM_TRANSFER_AMOUNT=1.00
# Max retry attempts per CommissionLedgerEntry before manual triage.
MAX_TRANSFER_RETRIES=3
# Background retry-loop cadence (seconds). 600 = 10 minutes.
FRANCHISEE_PAYOUT_RETRY_INTERVAL_SECONDS=600

# ===========================================
# OCPP & Server Tuning (Optional - defaults shown)
# ===========================================
SUSPEND_TIMEOUT_SECONDS=300
OCPP_TIMEOUT=120
# Auto-stop a session if the energy register stalls for this many seconds.
# Catches taper-completed EVs and stuck chargers. TTL on the watchdog
# Redis state must remain strictly greater than this value.
ZERO_ENERGY_TIMEOUT_SECONDS=7200
ZERO_ENERGY_GRACE_PERIOD_SECONDS=60
DISCONNECT_SUSPEND_TIMEOUT_SECONDS=180
# Grace period for socket-style chargers reporting Available status
# instead of immediately failing the transaction.
SOCKET_GRACE_PERIOD_SECONDS=300
# Disconnect-handler safeguards (services/disconnect_handler.py + transaction_finalizer.py)
MAX_DISCONNECT_RESETS_WITHOUT_PROGRESS=3
MAX_RESUME_GAP_SECONDS=900
RETENTION_DAYS=90
CLEANUP_INTERVAL_HOURS=24
DEBUG=false

# ===========================================
# VoltLync supplier identity (REQUIRED for GST invoices)
# ===========================================
VOLTLYNC_BUSINESS_NAME=VOLTLYNC PRIVATE LIMITED
VOLTLYNC_GSTIN=                       # 15-char GSTIN; invoices not issued when empty
VOLTLYNC_ADDRESS=
VOLTLYNC_STATE=Kerala
VOLTLYNC_STATE_CODE=32

# ===========================================
# Invoice PDF persistence (S3, lazy upload)
# ===========================================
AWS_REGION=ap-south-1
AWS_S3_INVOICE_BUCKET=voltlync-invoices-staging

# ===========================================
# Firmware update (S3 storage + retry scheduler)
# ===========================================
AWS_S3_FIRMWARE_BUCKET=voltlync-firmware-staging
FIRMWARE_PUBLIC_BASE_URL=https://staging.voltlync.com
FIRMWARE_MAX_ATTEMPTS=5
FIRMWARE_MAX_ELAPSED_SECONDS=21600
FIRMWARE_ATTEMPT_TIMEOUT_SECONDS=7200
FIRMWARE_BOOT_DEBOUNCE_SECONDS=300
