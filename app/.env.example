# API Configuration
# For local web development: use http://localhost:8000
# For mobile device testing: use your computer's local IP (e.g., http://192.168.1.100:8000)
# For production builds: use https://lyncpower.com
# Note: Native apps automatically use production URL, web uses this value
VITE_API_URL=http://localhost:8000

# Clerk Authentication
# Get your key from: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Razorpay (for payments)
# Get your key from: https://dashboard.razorpay.com
# Use test keys for development: rzp_test_*
# Use live keys for production: rzp_live_*
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# New Relic Browser Monitoring (Mobile App)
# Get these values from New Relic: APM & Services → Browser → Application Settings → Copy/Paste JavaScript
# ⭐ CRITICAL: Distributed tracing must be enabled to connect mobile app → backend traces
# Note: Uses Browser agent (not native SDK) since Capacitor apps run web code in WebView
VITE_NEW_RELIC_BROWSER_LICENSE_KEY=your_browser_license_key
VITE_NEW_RELIC_APPLICATION_ID=your_app_id
VITE_NEW_RELIC_ACCOUNT_ID=your_account_id
VITE_NEW_RELIC_TRUST_KEY=your_trust_key
VITE_NEW_RELIC_AGENT_ID=your_agent_id

# To disable monitoring (e.g., in development), simply don't set these variables
# or leave VITE_NEW_RELIC_BROWSER_LICENSE_KEY empty
