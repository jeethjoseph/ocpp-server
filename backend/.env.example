# Environment Configuration
ENVIRONMENT=development  # development, staging, production

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Redis Configuration (optional for now)
REDIS_URL=redis://localhost:6379

# Monitoring Configuration
# New Relic APM - Backend
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=OCPP-Backend-Dev
NEW_RELIC_MONITOR_MODE=false  # Set to true to enable monitoring
NEW_RELIC_LOG_LEVEL=info

# ⭐ DISTRIBUTED TRACING - CRITICAL FOR END-TO-END VISIBILITY
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
NEW_RELIC_SPAN_EVENTS_ENABLED=true

# Transaction Tracing (shows time breakdown)
NEW_RELIC_TRANSACTION_TRACER_ENABLED=true
NEW_RELIC_TRANSACTION_TRACER_RECORD_SQL=obfuscated  # Shows SQL queries

# Database Query Profiling
NEW_RELIC_SLOW_SQL_ENABLED=true

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0  # 100% sampling in development
SENTRY_PROFILES_SAMPLE_RATE=1.0  # 100% profiling in development
SENTRY_ENABLED=false  # Set to true to enable Sentry

# OCPP & Server Tuning
SUSPEND_TIMEOUT_SECONDS=300      # Seconds before auto-stopping a SUSPENDED transaction
OCPP_TIMEOUT=120                 # Seconds of inactivity before a charger is considered dead
RETENTION_DAYS=90                # Days to keep signal quality data and OCPP logs
CLEANUP_INTERVAL_HOURS=24        # Hours between data retention cleanup runs
DEBUG=false                      # Set to true to enable uvicorn reload

# Clerk Authentication
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# QR Payment Configuration (Appless Charging)
RAZORPAY_PLATFORM_FEE_PERCENT=2.0    # Razorpay platform fee percentage
MINIMUM_REFUND_AMOUNT=1.0            # Minimum refund amount in rupees
QR_PAYMENT_SAFETY_BUFFER=5.0         # Safety buffer in rupees for auto-stop
QR_PAYMENT_PENDING_TIMEOUT=300       # Seconds to wait for plug-in before refund

# Admin Panel
FASTADMIN_SECRET_KEY=your_fastadmin_secret_key