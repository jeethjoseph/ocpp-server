# ===========================================
# Docker Environment Configuration - DEVELOPMENT
# Copy this file to .env and fill in values
# ===========================================

# Environment Mode
ENVIRONMENT=development  # development, staging, production

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN_NAME=localhost

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=ocpp
DB_PASSWORD=ocpp_password_change_me
DB_NAME=ocpp_db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Backend Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=info

# ===========================================
# Frontend Configuration
# ===========================================
# For development: use localhost via nginx
NEXT_PUBLIC_API_URL=http://localhost

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# Monitoring Configuration (Optional - disabled for dev)
# ===========================================

# New Relic APM
NEW_RELIC_MONITOR_MODE=false
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=OCPP-Server-Dev

# Sentry Error Tracking
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ===========================================
# Frontend New Relic Browser (Optional)
# ===========================================
NEXT_PUBLIC_NEW_RELIC_BROWSER_LICENSE_KEY=
NEXT_PUBLIC_NEW_RELIC_APPLICATION_ID=
NEXT_PUBLIC_NEW_RELIC_ACCOUNT_ID=
NEXT_PUBLIC_NEW_RELIC_TRUST_KEY=
NEXT_PUBLIC_NEW_RELIC_AGENT_ID=

# ===========================================
# Clerk Authentication (Optional for local dev)
# ===========================================
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ===========================================
# Razorpay Payment Gateway (Optional for local dev)
# ===========================================
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
