# ===========================================
# Docker Environment Configuration - DEVELOPMENT
# Copy this file to .env and fill in values
# ===========================================

# Environment Mode
ENVIRONMENT=development  # development, staging, production

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN_NAME=localhost

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=ocpp
DB_PASSWORD=ocpp_password_change_me
DB_NAME=ocpp_db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Backend Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=info

# ===========================================
# Frontend Configuration
# ===========================================
# For development: use localhost via nginx
NEXT_PUBLIC_API_URL=http://localhost

# ===========================================
# Monitoring Configuration (Optional - disabled for dev)
# ===========================================

# New Relic APM
NEW_RELIC_MONITOR_MODE=false
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=OCPP-Server-Dev

# Sentry Error Tracking
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ===========================================
# Frontend New Relic Browser (Optional)
# ===========================================
NEXT_PUBLIC_NEW_RELIC_BROWSER_LICENSE_KEY=
NEXT_PUBLIC_NEW_RELIC_APPLICATION_ID=
NEXT_PUBLIC_NEW_RELIC_ACCOUNT_ID=
NEXT_PUBLIC_NEW_RELIC_TRUST_KEY=
NEXT_PUBLIC_NEW_RELIC_AGENT_ID=

# ===========================================
# Clerk Authentication (Optional for local dev)
# ===========================================
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ===========================================
# Razorpay Payment Gateway (Optional for local dev)
# ===========================================
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ===========================================
# OCPP & Server Tuning (Optional - defaults shown)
# ===========================================
SUSPEND_TIMEOUT_SECONDS=300
OCPP_TIMEOUT=120
ZERO_ENERGY_TIMEOUT_SECONDS=7200            # 2h — Redis state TTL must remain strictly greater
ZERO_ENERGY_GRACE_PERIOD_SECONDS=60
DISCONNECT_SUSPEND_TIMEOUT_SECONDS=180
RETENTION_DAYS=90
CLEANUP_INTERVAL_HOURS=24
DEBUG=true

# ===========================================
# Firmware update (S3 storage + retry scheduler)
# ===========================================
AWS_REGION=ap-south-1
AWS_S3_FIRMWARE_BUCKET=voltlync-firmware-dev
# Optional: legacy fallback for FirmwareFile rows with no s3_key
FIRMWARE_PUBLIC_BASE_URL=
# Retry tuning (defaults are sensible for production)
FIRMWARE_MAX_ATTEMPTS=5
FIRMWARE_MAX_ELAPSED_SECONDS=21600    # 6h wall-clock cap
FIRMWARE_ATTEMPT_TIMEOUT_SECONDS=7200 # 2h to declare an attempt failed if no boot
FIRMWARE_BOOT_DEBOUNCE_SECONDS=300    # ignore boots within 5m of last attempt
